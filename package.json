{
  "name": "@yumazak/joy",
  "version": "0.2.4",
  "description": "A terminal dashboard for monitoring Claude Code sessions in real-time.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "joy": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yumazak/joy.git"
  },
  "bugs": {
    "url": "https://github.com/yumazak/joy/issues"
  },
  "homepage": "https://github.com/yumazak/joy#readme",
  "keywords": [
    "claude-code",
    "tui",
    "hono",
    "node",
    "ink",
    "terminal"
  ],
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsup && node dist/main.js",
    "start": "node dist/main.js",
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --type-aware --type-check src"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "gunshi": "^0.29.2",
    "hono": "^4.9.8",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "oxlint": "^1.17.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
