{
  "name": "@yumazak/joy",
  "version": "0.1.1",
  "description": "A terminal dashboard for monitoring Claude Code sessions in real-time.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "joy": "src/main.tsx"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.test.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yumazak/joy.git"
  },
  "bugs": {
    "url": "https://github.com/yumazak/joy/issues"
  },
  "homepage": "https://github.com/yumazak/joy#readme",
  "keywords": [
    "claude-code",
    "tui",
    "hono",
    "bun",
    "terminal"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun run src/main.tsx",
    "start": "bun run src/main.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --type-aware --type-check src"
  },
  "dependencies": {
    "@opentui/core": "^0.1.86",
    "@opentui/react": "^0.1.86",
    "hono": "^4.9.8",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "oxlint": "^1.17.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
